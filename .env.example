# Sanity CMS — get these from https://www.sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# Public site URL for sitemap, Open Graph, and canonical links
NEXT_PUBLIC_SITE_URL=https://badwrx.vercel.app

# Set to true ONLY at public launch (enables indexing + removes preview password)
# Leave unset or false while the site is in preview — default is noindex everywhere.
NEXT_PUBLIC_SITE_PUBLIC=false

# Preview overlay password is in src/lib/site-preview.ts (temporary — remove before public launch)

# Local dev only: always show the age verification overlay (ignores localStorage)
# NEXT_PUBLIC_FORCE_AGE_GATE=true

# Editor token (API → Tokens in Sanity manage). Required for seed script
# AND for persisting submitted build requests to Sanity.
SANITY_API_TOKEN=

# Optional: secret for POST /api/revalidate (Sanity webhook on publish)
REVALIDATE_SECRET=

# Build request notifications (https://resend.com/api-keys)
RESEND_API_KEY=
# Comma-separated — both receive build request notifications by default
BUILD_NOTIFICATION_TO=info@badwrx.com,ernest@oddpluseven.com
# Any address @badwrx.com works once the domain is verified in Resend (no inbox required)
BUILD_NOTIFICATION_FROM="BADWRX Builds <builds@badwrx.com>"
# Optional overrides for Long Range University registration emails (defaults to BUILD_* above)
# UNIVERSITY_NOTIFICATION_TO=info@badwrx.com,ernest@oddpluseven.com
# UNIVERSITY_NOTIFICATION_FROM="BADWRX University <info@badwrx.com>"

# Optional: protect POST /api/square/deposit-invoice in production
BUILD_ADMIN_API_KEY=

# Square — build deposit invoices + automatic merch checkout
# Create an app, enable Invoices + Orders + Customers, then copy credentials.
# Merch checkout creates and publishes an invoice immediately on order submit.
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
# sandbox (default) or production
SQUARE_ENVIRONMENT=sandbox
