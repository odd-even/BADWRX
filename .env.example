# Sanity CMS — get these from https://www.sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# Preview site password — when set, all pages require login (leave empty for local dev)
SITE_PASSWORD=

# Editor token (API → Tokens in Sanity manage). Required for seed script
# AND for persisting submitted build requests to Sanity.
SANITY_API_TOKEN=

# Build request notifications (https://resend.com/api-keys)
RESEND_API_KEY=
# Where build requests are emailed (defaults to ernest@oddpluseven.com)
BUILD_NOTIFICATION_TO=ernest@oddpluseven.com
# Verified sender on your Resend domain (defaults to builds@oddpluseven.com)
BUILD_NOTIFICATION_FROM="BADWRX Builds <builds@oddpluseven.com>"

# Optional: protect POST /api/square/deposit-invoice in production
BUILD_ADMIN_API_KEY=

# Square — deposit invoices (https://developer.squareup.com/apps)
# Create an app, enable Invoices + Orders + Customers, then copy credentials.
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
# sandbox (default) or production
SQUARE_ENVIRONMENT=sandbox
